{
  "name": "jiosaavn-api",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "description": "Unofficial JioSaavn API",
  "type": "module",
  "license": "MIT",
  "repository": "https://github.com/sumitkolhe/jiosaavn-api",
  "author": "Sumit Kolhe",
  "imports": {
    "#modules/*": "./src/modules/*",
    "#common/*": "./src/common/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "deploy": "NITRO_PRESET=cloudflare_module vite build && wrangler deploy",
    "format": "prettier --write \"./**/*.{js,ts,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "prerelease": "pnpm test",
    "release": "changelogen --release --push",
    "spell-check": "cspell .",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm format",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.19.2",
    "@hono/zod-validator": "^0.4.3",
    "@scalar/hono-api-reference": "^0.7.4",
    "consola": "^3.4.2",
    "hono": "^4.7.5",
    "node-forge": "^1.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@kolhe/eslint-config": "2.2.6",
    "@types/node": "^22.13.14",
    "@types/node-forge": "^1.3.11",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "changelogen": "^0.6.1",
    "cspell": "8.18.1",
    "eslint": "^9.23.0",
    "eslint-plugin-prettier": "^5.2.5",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^5.8.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.6.0"
  }
}
