{
  "name": "jiosaavn-api",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.2",
  "description": "Unofficial JioSaavn API",
  "author": "Sumit Kolhe",
  "license": "MIT",
  "repository": "https://github.com/sumitkolhe/jiosaavn-api",
  "imports": {
    "#modules/*": "./src/modules/*",
    "#common/*": "./src/common/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "deploy": "NITRO_PRESET=cloudflare_module vite build && wrangler deploy",
    "format": "prettier --write \"./**/*.{js,ts,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "prerelease": "pnpm test",
    "release": "changelogen --release --push",
    "spell-check": "cspell .",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@scalar/hono-api-reference": "^0.10.20",
    "consola": "^3.4.2",
    "hono": "^4.12.23",
    "node-forge": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@kolhe/eslint-config": "3.3.0",
    "@types/node": "^25.9.2",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "changelogen": "^0.6.2",
    "cspell": "10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm format",
    "commit-msg": "pnpm exec commitlint --edit $1"
  }
}
